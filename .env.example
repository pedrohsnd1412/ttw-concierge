# ---------------------------------------------------------------------------
# TTW Concierge — variáveis de ambiente
# ---------------------------------------------------------------------------
# Duplique este arquivo como `.env.local` e preencha apenas no ambiente local.
# Em produção, cadastre os mesmos valores nas variáveis protegidas da Vercel.

# Credenciais de acesso ao app (login do consultor).
TTW_USER=consultor@ttw.com
TTW_PASSWORD=
TTW_AUTH_SECRET=

# Dica de acesso exibida na tela de login (use só em deploy de DEMONSTRAÇÃO).
# Ex.: NEXT_PUBLIC_DEMO_CRED="consultor@ttw.com / suasenha"
NEXT_PUBLIC_DEMO_CRED=

# --- Supabase (OPCIONAL — caminho de produção do Concierge) ---------------
# Por padrão o Concierge roda 100% no índice TF-IDF local (instantâneo, offline).
# Para usar a busca vetorial pgvector no Supabase, defina USE_SUPABASE=1 E
# preencha as três variáveis abaixo. Sem USE_SUPABASE=1, o Supabase é ignorado.
USE_SUPABASE=
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SECRET_KEY=

# Provedor de embeddings para a ingestão (scripts/ingest_supabase.mjs)
# Padrão: OpenAI text-embedding-3-small (1536 dimensões)
# OPENAI_API_KEY=
# EMBEDDING_MODEL=text-embedding-3-small
