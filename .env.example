# ---------------------------------------------------------------------------
# TTW Concierge — variáveis de ambiente
# ---------------------------------------------------------------------------
# Duplique este arquivo como `.env.local` e preencha apenas no ambiente local.
# Em produção, cadastre os mesmos valores nas variáveis protegidas da Vercel.

# Credenciais de acesso ao app (login do consultor).
TTW_USER=consultor@ttw.com
TTW_PASSWORD=
TTW_AUTH_SECRET=

# --- Supabase (opcional para os dados de conteúdo) ------------------------
# Se preenchido, o Concierge e o Descobridor passam a usar busca vetorial
# (pgvector) no Supabase em vez do índice local.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SECRET_KEY=

# Provedor de embeddings para a ingestão (scripts/ingest_supabase.mjs)
# Padrão: OpenAI text-embedding-3-small (1536 dimensões)
# OPENAI_API_KEY=
# EMBEDDING_MODEL=text-embedding-3-small
